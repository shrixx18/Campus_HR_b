# PostgreSQL
POSTGRES_USER=campushire
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# JWT
JWT_SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=campushire
RABBITMQ_PASSWORD=change_me_rabbitmq_password

# SMTP (use Mailtrap for dev)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@campushire.local

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/data/uploads
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=campushire

# Service URLs (internal Docker network)
IDENTITY_SERVICE_URL=http://identity-service:8001
OPPORTUNITY_SERVICE_URL=http://opportunity-service:8002
APPLICATION_SERVICE_URL=http://application-service:8003
COMMUNICATIONS_SERVICE_URL=http://communications-service:8004
